generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ChatSession {
  id            String    @id @default(uuid())
  userId        String    // Firebase UID
  title         String    @default("New Chat")
  memorySummary String?
  isPinned      Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  messages      Message[]

  @@index([userId])
}

model Message {
  id                      String      @id @default(uuid())
  chatSessionId           String
  role                    String      // "user" or "model"
  text                    String
  timestamp               DateTime    @default(now())
  
  // JSON field for storing the image object: { data: string, mimeType: string, name: string }
  image                   Json?
  
  // JSON field for array of alternative texts
  alternatives            Json?
  currentAlternativeIndex Int?

  chatSession             ChatSession @relation(fields: [chatSessionId], references: [id], onDelete: Cascade)

  @@index([chatSessionId])
  @@index([timestamp])
  @@index([text])
}

model UserGlobalMemory {
  userId    String   @id // Firebase UID
  memory    Json     // Store preferences, sensitivities, locations, routines, etc.
  updatedAt DateTime @updatedAt
}

model WorldCupMatch {
  id            String   @id                    // e.g. "por_cod_2026" or API fixture ID
  fdApiId       Int?     @unique                // Football-Data.org fixture ID for mapping
  group         String                          // e.g. "Group K"
  round         String   @default("Round 1")    // e.g. "Round 1"
  homeName      String
  homeCode      String                          // ISO country code e.g. "PT"
  awayName      String
  awayCode      String                          // ISO country code e.g. "CD"
  kickoff       DateTime
  venueName     String?
  venueCity     String?
  status        String   @default("scheduled")  // scheduled | live | finished
  scoreHome     Int      @default(0)
  scoreAway     Int      @default(0)
  htScoreHome   Int?                            // Half-time score
  htScoreAway   Int?
  elapsed       Int?
  votesHome     Int      @default(0)
  votesDraw     Int      @default(0)
  votesAway     Int      @default(0)
  stats         Json?                           // { possession, shots, ... }
  lastSyncedAt  DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([status])
  @@index([kickoff])
  @@index([group])
}

model Prediction {
  id         String   @id @default(uuid())
  matchId    String
  userId     String
  username   String?
  choice     String   // home | draw | away
  points     Int      @default(0)
  isCorrect  Boolean? // null = pending, true = correct, false = incorrect
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([userId, matchId])
  @@index([matchId])
  @@index([userId])
}
